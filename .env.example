# Copy to .env and paste the tunnel token from the Cloudflare Zero Trust dashboard.
# Networks > Tunnels > (your tunnel) > Configure > Docker. .env is gitignored.
TUNNEL_TOKEN=

# Only used by docker-compose.prod.yml on the VPS (the pull-not-build setup).
# Your Docker Hub image, e.g. yourdockerhubuser/portofolio-web:latest
WEB_IMAGE=
